<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:bzTorrentClient.Avalonia.Features.StatusFooter"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="32"
             x:Class="bzTorrentClient.Avalonia.Features.StatusFooter.StatusFooterView"
             x:DataType="vm:StatusFooterViewModel">

    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" Spacing="18" Margin="16,6">
            <TextBlock Classes="Caption" Text="{Binding DhtNodeCount, StringFormat='DHT: {0} nodes'}"/>
            <TextBlock Classes="Caption" Text="{Binding DhtPeersFound, StringFormat='{}{0} peers'}"/>
            <Rectangle Width="1" Height="14" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush1}"/>
            <TextBlock Classes="Caption" Text="{Binding PexPeersFound, StringFormat='PEX: {0} peers'}"/>
            <Rectangle Width="1" Height="14" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush1}"/>
            <TextBlock Classes="Caption" Text="{Binding LanPeersFound, StringFormat='LAN: {0} peers'}"/>
            <Rectangle Width="1" Height="14" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush1}"/>
            <TextBlock Classes="Caption" Text="{Binding TrackerPeersFound, StringFormat='Trackers: {0} peers'}"/>
            <Rectangle Width="1" Height="14" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush1}"/>
            <TextBlock Classes="Caption" Text="{Binding DownloadSpeedText, StringFormat='↓ {0}'}"/>
            <TextBlock Classes="Caption" Text="{Binding UploadSpeedText, StringFormat='↑ {0}'}"/>
        </StackPanel>
    </Border>

</UserControl>
