<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:bzTorrentClient.Avalonia.Features.TorrentDetails"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="600"
             x:Class="bzTorrentClient.Avalonia.Features.TorrentDetails.TorrentDetailsView"
             x:DataType="vm:TorrentDetailsViewModel">

    <Grid>

        <!-- Empty state: an invitation to act, not a blank pane. -->
        <StackPanel IsVisible="{Binding !HasSelection}" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="24" Spacing="6" MaxWidth="220">
            <TextBlock Classes="Heading" Text="No torrent selected" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Classes="Caption" Text="Pick a torrent from the list to see its peers, files, and download progress here."
                       TextAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <DockPanel IsVisible="{Binding HasSelection}" Margin="{StaticResource SpaceLgThickness}">

            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
                <TextBlock Classes="Title" Text="{Binding Name}" TextWrapping="Wrap"/>
                <TextBlock Classes="Mono" Text="{Binding InfoHash}"/>
                <TextBlock Classes="Caption" Text="{Binding DownloadDirectory}" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Signature: the piece-map heat strip — every torrent client's real "fingerprint"
                 of what's actually been verified on disk, not just a percentage. -->
            <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,16" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Classes="Caption" Text="PIECE MAP"/>
                    <ItemsControl ItemsSource="{Binding PieceMap}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PieceMapCell">
                                <Grid Width="7" Height="7" Margin="0.5">
                                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="1.5"/>
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="1.5" Opacity="{Binding Fill}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TabControl>
                <TabItem Header="Peers">
                    <ListBox ItemsSource="{Binding Peers}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PeerRowViewModel">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" Margin="0,2">
                                    <TextBlock Grid.Column="0" Classes="Mono" Text="{Binding EndPoint}" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <Border Classes="Pill">
                                            <TextBlock Classes="Caption" Text="{Binding Transport, Converter={x:Static vm:PeerActivityConverters.TransportToText}}"/>
                                        </Border>
                                        <TextBlock Classes="Caption" Text="🔒" IsVisible="{Binding IsEncrypted}" ToolTip.Tip="MSE encrypted"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                Opacity="{Binding IsDownloading, Converter={x:Static vm:PeerActivityConverters.ToOpacity}}"
                                                ToolTip.Tip="Downloading from this peer">
                                        <TextBlock Classes="Caption" Text="↓"/>
                                        <TextBlock Classes="Caption" Text="{Binding DownloadSpeedText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                                                Opacity="{Binding IsUploading, Converter={x:Static vm:PeerActivityConverters.ToOpacity}}"
                                                ToolTip.Tip="Uploading to this peer">
                                        <TextBlock Classes="Caption" Text="↑"/>
                                        <TextBlock Classes="Caption" Text="{Binding UploadSpeedText}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="Files">
                    <Grid>
                        <TextBlock IsVisible="{Binding IsFetchingMetadata}" Classes="Caption" Text="(fetching metadata…)"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ListBox IsVisible="{Binding !IsFetchingMetadata}" ItemsSource="{Binding Files}" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:FileRowViewModel">
                                    <StackPanel Spacing="2" Margin="0,4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Classes="Body" Text="{Binding Filename}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Classes="Caption" Text="{Binding FileSizeText}" Margin="8,0,0,0"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <ProgressBar Grid.Column="0" VerticalAlignment="Center"
                                                         Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"/>
                                            <TextBlock Grid.Column="1" Classes="Caption" Text="{Binding ProgressPercent, StringFormat={}{0}%}"/>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Trackers">
                    <ListBox ItemsSource="{Binding Trackers}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrackerRowViewModel">
                                <StackPanel Spacing="2" Margin="0,4">
                                    <TextBlock Classes="Body" Text="{Binding Url}" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Classes="Caption" Text="{Binding PeersFound, StringFormat='{}{0} peers found'}"/>
                                        <TextBlock Classes="Caption" Text="{Binding SeedersText, StringFormat='{}{0} seeds'}"/>
                                        <TextBlock Classes="Caption" Text="{Binding LeechersText, StringFormat='{}{0} leeches'}"/>
                                        <TextBlock Classes="Caption" Text="{Binding LastAnnounceText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="Info">
                    <StackPanel Spacing="10" Margin="0,4">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="Caption" Text="TOTAL SIZE"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="Body" Text="{Binding TotalSizeText}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="Caption" Text="DATE ADDED"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="Body" Text="{Binding DateAddedText}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="Caption" Text="PRIVATE"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="Body" Text="{Binding IsPrivateText}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Classes="Caption" Text="PIECES"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Classes="Body" Text="{Binding PieceInfoText}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Classes="Caption" Text="CREATED BY"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="Body" Text="{Binding CreatedByText}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Classes="Caption" Text="CREATED ON"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Classes="Body" Text="{Binding CreatedOnText}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Classes="Caption" Text="COMMENT" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Classes="Body" Text="{Binding Comment}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Grid>

</UserControl>
