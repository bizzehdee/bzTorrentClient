<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="bzTorrentClient.Avalonia.App"
             xmlns:local="using:bzTorrentClient.Avalonia"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://bzTorrentClient.Avalonia/Styles/Tokens.axaml"/>
                <ResourceInclude Source="avares://bzTorrentClient.Avalonia/Styles/Icons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <!-- TorrentTeal accent — same in both variants; only base grays flip. -->
                <ColorPaletteResources x:Key="Light" Accent="#0EA5B7"/>
                <ColorPaletteResources x:Key="Dark" Accent="#0EA5B7"/>
            </FluentTheme.Palettes>
        </FluentTheme>
        <StyleInclude Source="avares://bzTorrentClient.Avalonia/Styles/Typography.axaml"/>
        <StyleInclude Source="avares://bzTorrentClient.Avalonia/Styles/Controls.axaml"/>
    </Application.Styles>
</Application>
