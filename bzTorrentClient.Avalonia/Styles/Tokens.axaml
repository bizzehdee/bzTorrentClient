<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Design tokens for the "command rail + swarm list + inspector" layout.
    Palette: TorrentTeal (accent) / Ink & Paper (base) / Cloud & Slate (surfaces)
    / Ember, Moss, Amber (state colors, used with a label — never color alone).
  -->

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <Color x:Key="AppBackgroundColor">#F9F9F9</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="SurfaceAltColor">#F1F3F4</Color>
      <Color x:Key="BorderColor">#E5E5E5</Color>
      <Color x:Key="TextPrimaryColor">#1C1C1C</Color>
      <Color x:Key="TextSecondaryColor">#5F5F5F</Color>
      <BoxShadows x:Key="CardShadow">0 1 4 0 #22000000</BoxShadows>
      <BoxShadows x:Key="CardShadowHover">0 2 10 0 #22000000</BoxShadows>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="AppBackgroundColor">#121212</Color>
      <Color x:Key="SurfaceColor">#1E1E1E</Color>
      <Color x:Key="SurfaceAltColor">#242424</Color>
      <Color x:Key="BorderColor">#2A2A2A</Color>
      <Color x:Key="TextPrimaryColor">#EDEDED</Color>
      <Color x:Key="TextSecondaryColor">#A0A0A0</Color>
      <BoxShadows x:Key="CardShadow">0 1 4 0 #55000000</BoxShadows>
      <BoxShadows x:Key="CardShadowHover">0 2 10 0 #55000000</BoxShadows>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}"/>
  <SolidColorBrush x:Key="BorderBrush1" Color="{DynamicResource BorderColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}"/>

  <!-- Accent: TorrentTeal — a network/data-flow color, distinct from the default Windows blue. -->
  <Color x:Key="AccentColor">#0EA5B7</Color>
  <Color x:Key="AccentColorHover">#12B9CE</Color>
  <Color x:Key="AccentColorPressed">#0B8494</Color>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentColorHover}"/>
  <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentColorPressed}"/>
  <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF"/>

  <!-- Torrent-state semantics: always paired with a text label, never color alone. -->
  <Color x:Key="StateActiveColor">#0EA5B7</Color>
  <Color x:Key="StateCompletedColor">#4CAF7D</Color>
  <Color x:Key="StatePausedColor">#E0A840</Color>
  <Color x:Key="StateStoppedColor">#8A8A8A</Color>
  <Color x:Key="StateErrorColor">#D9534F</Color>
  <SolidColorBrush x:Key="StateActiveBrush" Color="{StaticResource StateActiveColor}"/>
  <SolidColorBrush x:Key="StateCompletedBrush" Color="{StaticResource StateCompletedColor}"/>
  <SolidColorBrush x:Key="StatePausedBrush" Color="{StaticResource StatePausedColor}"/>
  <SolidColorBrush x:Key="StateStoppedBrush" Color="{StaticResource StateStoppedColor}"/>
  <SolidColorBrush x:Key="StateErrorBrush" Color="{StaticResource StateErrorColor}"/>

  <!-- 8px spacing grid: doubles for Spacing (StackPanel etc.), Thickness for Margin/Padding. -->
  <x:Double x:Key="SpaceXs">4</x:Double>
  <x:Double x:Key="SpaceSm">8</x:Double>
  <x:Double x:Key="SpaceMd">16</x:Double>
  <x:Double x:Key="SpaceLg">24</x:Double>
  <x:Double x:Key="SpaceXl">32</x:Double>

  <Thickness x:Key="SpaceMdThickness">16</Thickness>
  <Thickness x:Key="SpaceLgThickness">24</Thickness>

  <!-- Corner radii -->
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">10</CornerRadius>
  <CornerRadius x:Key="RadiusLg">14</CornerRadius>
  <CornerRadius x:Key="RadiusPill">999</CornerRadius>

  <FontFamily x:Key="MonoFontFamily">Cascadia Mono,Cascadia Code,Consolas,monospace</FontFamily>

</ResourceDictionary>
