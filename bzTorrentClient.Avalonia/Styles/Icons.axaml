<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Hand-authored 20x20 glyph set, all as closed FILLED shapes — Avalonia's PathIcon
       paints Data via Foreground fill only (no stroke), so the earlier open-line versions
       of Close/Plus/Settings (single strokes with zero enclosed area) rendered as nothing.
       Kept as our own vector geometry rather than a platform icon font, so Windows and
       Linux render pixel-identical glyphs. -->

  <StreamGeometry x:Key="IconPlay">M6,4 L16,10 L6,16 Z</StreamGeometry>
  <StreamGeometry x:Key="IconPause">M6,4 L9,4 L9,16 L6,16 Z M11,4 L14,4 L14,16 L11,16 Z</StreamGeometry>
  <StreamGeometry x:Key="IconStop">M5,5 L15,5 L15,15 L5,15 Z</StreamGeometry>
  <StreamGeometry x:Key="IconClose">M5,6.5 L6.5,5 L15,13.5 L13.5,15 Z M13.5,5 L15,6.5 L6.5,15 L5,13.5 Z</StreamGeometry>
  <StreamGeometry x:Key="IconPlus">M8.5,4 L11.5,4 L11.5,8.5 L16,8.5 L16,11.5 L11.5,11.5 L11.5,16 L8.5,16 L8.5,11.5 L4,11.5 L4,8.5 L8.5,8.5 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSettings">M4,5.2 L16,5.2 L16,6.8 L4,6.8 Z M4,9.2 L12,9.2 L12,10.8 L4,10.8 Z M4,13.2 L14,13.2 L14,14.8 L4,14.8 Z</StreamGeometry>

</ResourceDictionary>
